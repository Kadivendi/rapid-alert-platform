# Database (used by every per-service Postgres in docker-compose)
POSTGRES_USER=rapidalert_user
POSTGRES_PASSWORD=rapidalert_secure_password

# JWT signing key — base64-encoded 32+ bytes. If unset, security-service generates a
# per-boot random key and logs a WARN. MUST be set in any deployed environment so
# tokens survive restarts and rotate intentionally.
# Generate locally with:  openssl rand -base64 64
JWT_SIGNING_KEY=

# Telegram integration (telegram-bot-server)
TELEGRAM_BOT_NAME=RapidAlertBot
TELEGRAM_BOT_TOKEN=

# Kafka — overridden inside docker-compose to broker:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Eureka discovery — overridden inside docker-compose to discovery-server:8761
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka

# Mesh failover signal (resilient-mesh-gateway endpoint)
MESH_FAILOVER_ENDPOINT=http://resilient-mesh-gateway:8090/api/mesh/broadcast
MESH_FAILOVER_THRESHOLD=0.80
